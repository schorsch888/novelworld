# ═══════════════════════════════════════════════════════════════════════════
# NovelWorld 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ═══════════════════════════════════════════════════════════════════════════

# ─── PostgreSQL 18 ─────────────────────────────────────────────────────────
POSTGRES_USER=novel
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=novel_world

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_PASSWORD=your_redis_password_here

# ─── JWT ───────────────────────────────────────────────────────────────────
# 必须至少 32 个字符，生产环境使用随机字符串
JWT_SECRET=change_me_to_a_random_32_char_string
JWT_EXPIRY_HOURS=24

# ─── LLM API（支持 OpenAI 兼容接口）──────────────────────────────────────
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-openai-api-key
LLM_MODEL=gpt-4o-mini

# ─── 图像生成 API ──────────────────────────────────────────────────────────
IMAGE_GEN_API_URL=https://api.openai.com/v1
IMAGE_GEN_API_KEY=sk-your-openai-api-key

# ─── S3 对象存储（用于小说文件和角色头像）────────────────────────────────
# 支持 AWS S3、MinIO、阿里云 OSS 等兼容接口
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=novel-world-uploads
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key

# ─── 前端配置 ──────────────────────────────────────────────────────────────
VITE_API_URL=/api
CORS_ORIGINS=http://localhost:5173,https://your-domain.com

# ─── 记忆系统配置 ──────────────────────────────────────────────────────────
MEMORY_SHORT_TERM_LIMIT=20     # 短期记忆最大条数
MEMORY_MID_TERM_LIMIT=50       # 中期记忆最大条数
MEMORY_COMPRESS_THRESHOLD=15   # 触发压缩的短期记忆条数阈值
