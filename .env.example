# ═══════════════════════════════════════════════════════════════════════════
# NovelWorld Environment Variables
# Copy to .env and fill in your values. Only LLM_API_KEY is required.
# ═══════════════════════════════════════════════════════════════════════════

# ─── PostgreSQL 18 ─────────────────────────────────────────────────────────
POSTGRES_USER=novel
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=novel_world

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_PASSWORD=your_redis_password_here

# ─── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_random_32_char_string
JWT_EXPIRY_HOURS=24

# ─── LLM Providers ────────────────────────────────────────────────────────
# Set any API key below — the system auto-detects which providers are available.
# You only need ONE provider to get started.

# Generic fallback (any OpenAI-compatible API)
LLM_API_KEY=sk-your-api-key
LLM_API_URL=https://api.openai.com
LLM_MODEL=gpt-4o-mini
# LLM_PROVIDER=openai              # override default provider

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# GEMINI_API_KEY=...

# DeepSeek
# DEEPSEEK_API_KEY=sk-...

# 豆包 Doubao (ByteDance)
# DOUBAO_API_KEY=...
# DOUBAO_REGION=cn                  # cn (default) or intl

# 通义千问 Qwen (Alibaba)
# QWEN_API_KEY=...                  # or DASHSCOPE_API_KEY
# QWEN_REGION=cn                    # cn (default) or intl

# GLM 智谱AI (ZhipuAI)
# GLM_API_KEY=...                   # or ZHIPU_API_KEY
# GLM_REGION=cn                     # cn (default) or intl

# MiniMax
# MINIMAX_API_KEY=...

# Moonshot / Kimi
# MOONSHOT_API_KEY=...

# 百川 Baichuan
# BAICHUAN_API_KEY=...

# 阶跃星辰 Stepfun
# STEPFUN_API_KEY=...

# 零一万物 Yi
# YI_API_KEY=...

# 讯飞星火 Spark
# SPARK_API_KEY=...

# 小米 Xiaomi
# XIAOMI_API_KEY=...

# Mistral
# MISTRAL_API_KEY=...

# Groq
# GROQ_API_KEY=...

# Together AI
# TOGETHER_API_KEY=...

# ─── Embeddings ────────────────────────────────────────────────────────────
# Falls back to LLM provider if not set
# EMBEDDING_API_URL=https://api.openai.com
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small

# ─── Image Generation ─────────────────────────────────────────────────────
IMAGE_GEN_API_URL=https://api.openai.com
IMAGE_GEN_API_KEY=sk-your-api-key

# ─── S3 Object Storage ────────────────────────────────────────────────────
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_BUCKET=novel-world-uploads
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key

# ─── Frontend ─────────────────────────────────────────────────────────────
VITE_API_URL=/api
CORS_ORIGINS=http://localhost:5173,https://your-domain.com

# ─── Memory System ────────────────────────────────────────────────────────
MEMORY_SHORT_TERM_LIMIT=20
MEMORY_MID_TERM_LIMIT=50
MEMORY_COMPRESS_THRESHOLD=15
